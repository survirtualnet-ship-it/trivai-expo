# Copiar a .env.local para desarrollo local
# En Vercel: Project Settings → Environment Variables (build time)

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Google Maps (JavaScript API, Static Maps, Geocoding en nativo)
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key

# URL pública de esta app (share links, PWA)
EXPO_PUBLIC_APP_URL=https://trivai-expo.vercel.app

# Backend web Next.js (proxy APIs si se necesitan en web)
EXPO_PUBLIC_WEB_API_URL=https://trivai.vercel.app

# Solo scripts locales (NO commitear, NO usar EXPO_PUBLIC_)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
